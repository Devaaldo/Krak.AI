# Salin file ini jadi `.env` lalu isi nilainya. JANGAN commit `.env` (sudah di-gitignore).
# Di Hugging Face Spaces, set variabel ini lewat Settings > Variables and secrets.

# --- CORS ---
# Daftar origin frontend yang diizinkan, dipisah koma.
# Contoh: http://localhost:5173,https://krak-ai.vercel.app
FRONTEND_ORIGINS=

# --- Layer GenAI (AI Engineer) ---
# Wajib untuk fitur Advisor (RAG), Report, VLM fallback, dan Agent.
# Ambil gratis di Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model Gemini (teks + vision). Default sudah cukup untuk free tier.
GEMINI_MODEL=gemini-2.0-flash

# Provider LLM teks: "gemini" (default) atau "groq".
LLM_PROVIDER=gemini

# Opsional — hanya jika LLM_PROVIDER=groq (Gemma/Llama, gratis di console.groq.com).
GROQ_API_KEY=
GROQ_MODEL=gemma2-9b-it
