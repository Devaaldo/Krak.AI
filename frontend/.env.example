# Salin file ini jadi `.env` lalu sesuaikan nilainya.
# Variabel VITE_* ditanam saat BUILD — kalau diubah, wajib build/redeploy ulang.

# Alamat backend FastAPI (HTTP, dipakai halaman Import → POST /predict)
# Lokal:    http://localhost:8000
# Produksi: https://<user>-<space>.hf.space
VITE_API_URL=http://localhost:8000

# Alamat WebSocket backend (dipakai halaman Live webcam → /ws)
# Lokal:    ws://localhost:8000/ws
# Produksi: wss://<user>-<space>.hf.space/ws   (pakai wss, bukan ws, di HTTPS)
VITE_WS_URL=ws://localhost:8000/ws
